{
  "name": "php-project-analyzer",
  "version": "1.0.0",
  "description": "Visualizzatore grafico di progetti PHP - Correlazioni file, classi e database",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "preview": "vite build && electron .",
    "analyzer:install": "cd analyzer && composer install --no-interaction",
    "analyzer:test": "cd analyzer && php bin/analyze ../../.."
  },
  "dependencies": {
    "cytoscape": "^3.28.0",
    "cytoscape-dagre": "^2.5.0",
    "react": "^18.2.0",
    "react-cytoscapejs": "^2.0.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.projectmanager.analyzer",
    "productName": "PHP Project Analyzer",
    "files": [
      "dist/**/*",
      "electron/**/*",
      "analyzer/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "linux": {
      "target": ["AppImage", "deb"]
    },
    "mac": {
      "target": ["dmg"]
    },
    "win": {
      "target": ["nsis"]
    }
  }
}
