#!/usr/bin/env php
<?php
/**
 * DB cleanup script.
 * Reads JSON from stdin: { projectPath, actions: { dropTables: string[], dropColumns: { table: string, columns: string[] }[], deleteFiles: string[] } }
 * Outputs JSON: { ok: true, executed: string[], errors: string[] }
 */
$input = json_decode(file_get_contents('php://stdin'), true);
if (!$input || !isset($input['projectPath'])) {
    echo json_encode(['ok' => false, 'executed' => [], 'errors' => ['Input non valido']]);
    exit(1);
}

$projectPath = $input['projectPath'];
$actions = $input['actions'] ?? [];
$result = ['ok' => true, 'executed' => [], 'errors' => []];

$dropTables = $actions['dropTables'] ?? [];
$dropColumns = $actions['dropColumns'] ?? [];

// ── Detect DB config (same logic as analyze-db) ────────────────

$dotEnv = [];
$envPath = $projectPath . '/.env';
$envExamplePath = $projectPath . '/.env.example';
foreach ([$envPath, $envExamplePath] as $p) {
  if (file_exists($p)) {
    foreach (file($p, FILE_IGNORE_NEW_LINES | FILE_SKIP_EMPTY_LINES) as $line) {
      $line = trim($line);
      if ($line === '' || $line[0] === '#') continue;
      $parts = explode('=', $line, 2);
      if (count($parts) === 2) $dotEnv[trim($parts[0])] = trim($parts[1], '"\' ');
    }
    if (!empty($dotEnv)) break;
  }
}

$dbConfig = [
  'connection' => $dotEnv['DB_CONNECTION'] ?? $dotEnv['DB_DRIVER'] ?? $dotEnv['DATABASE_DRIVER'] ?? 'mysql',
  'host' => $dotEnv['DB_HOST'] ?? $dotEnv['DATABASE_HOST'] ?? '127.0.0.1',
  'port' => $dotEnv['DB_PORT'] ?? $dotEnv['DATABASE_PORT'] ?? null,
  'database' => $dotEnv['DB_DATABASE'] ?? $dotEnv['DATABASE_NAME'] ?? $dotEnv['DB_NAME'] ?? null,
  'username' => $dotEnv['DB_USERNAME'] ?? $dotEnv['DATABASE_USER'] ?? $dotEnv['DB_USER'] ?? 'root',
  'password' => $dotEnv['DB_PASSWORD'] ?? $dotEnv['DATABASE_PASSWORD'] ?? '',
];

if (!empty($dotEnv['DATABASE_URL'])) {
  $parts = parse_url($dotEnv['DATABASE_URL']);
  if ($parts) {
    $dbConfig['connection'] = $parts['scheme'] ?? 'mysql';
    $dbConfig['host'] = $parts['host'] ?? '127.0.0.1';
    $dbConfig['port'] = $parts['port'] ?? null;
    $dbConfig['database'] = ltrim($parts['path'] ?? '', '/');
    $dbConfig['username'] = $parts['user'] ?? 'root';
    $dbConfig['password'] = $parts['pass'] ?? '';
  }
}

$connLower = strtolower($dbConfig['connection']);

// Detect SQLite path
$isSqlite = $connLower === 'sqlite' || $connLower === 'sqlite3';
$sqlitePath = null;
if ($isSqlite && !empty($dbConfig['database'])) {
  $sqlitePath = $dbConfig['database'];
  if (!str_starts_with($sqlitePath, '/')) {
    $candidates = [
      $projectPath . '/database/' . $sqlitePath,
      $projectPath . '/' . $sqlitePath,
      $projectPath . '/storage/' . $sqlitePath,
    ];
    foreach ($candidates as $c) {
      if (file_exists($c)) { $sqlitePath = realpath($c); break; }
    }
  }
}
if (!$isSqlite) {
  foreach (['/database/database.sqlite', '/data/database.sqlite', '/app.db', '/db.sqlite'] as $rel) {
    $c = $projectPath . $rel;
    if (file_exists($c)) { $isSqlite = true; $sqlitePath = realpath($c); break; }
  }
}

// ── Execute SQL operations ─────────────────────────────────────

try {
    if ($isSqlite && $sqlitePath) {
        $db = new SQLite3($sqlitePath, SQLITE3_OPEN_READWRITE);
        $db->exec('PRAGMA foreign_keys = OFF');

        foreach ($dropTables as $tbl) {
            try {
                $db->exec('DROP TABLE IF EXISTS "' . SQLite3::escapeString($tbl) . '"');
                $result['executed'][] = "DROP TABLE $tbl";
            } catch (Throwable $e) {
                $result['errors'][] = "DROP TABLE $tbl: " . $e->getMessage();
            }
        }

        foreach ($dropColumns as $dc) {
            $tbl = $dc['table'];
            foreach ($dc['columns'] as $col) {
                try {
                    $db->exec('ALTER TABLE "' . SQLite3::escapeString($tbl) . '" DROP COLUMN "' . SQLite3::escapeString($col) . '"');
                    $result['executed'][] = "ALTER TABLE $tbl DROP COLUMN $col";
                } catch (Throwable $e) {
                    $result['errors'][] = "ALTER TABLE $tbl DROP COLUMN $col: " . $e->getMessage();
                }
            }
        }

        $db->close();
    } elseif (in_array($connLower, ['mysql', 'mariadb', 'mysqli'])) {
        $dsn = 'mysql:host=' . $dbConfig['host'];
        if (!empty($dbConfig['port'])) $dsn .= ';port=' . $dbConfig['port'];
        if (!empty($dbConfig['database'])) $dsn .= ';dbname=' . $dbConfig['database'];
        $pdo = new PDO($dsn, $dbConfig['username'], $dbConfig['password'], [
            PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION,
            PDO::ATTR_TIMEOUT => 10,
        ]);

        foreach ($dropTables as $tbl) {
            try {
                $pdo->exec("DROP TABLE IF EXISTS `" . str_replace('`', '``', $tbl) . "`");
                $result['executed'][] = "DROP TABLE $tbl";
            } catch (Throwable $e) {
                $result['errors'][] = "DROP TABLE $tbl: " . $e->getMessage();
            }
        }

        foreach ($dropColumns as $dc) {
            $tbl = $dc['table'];
            foreach ($dc['columns'] as $col) {
                try {
                    $pdo->exec("ALTER TABLE `" . str_replace('`', '``', $tbl) . "` DROP COLUMN `" . str_replace('`', '``', $col) . "`");
                    $result['executed'][] = "ALTER TABLE $tbl DROP COLUMN $col";
                } catch (Throwable $e) {
                    $result['errors'][] = "ALTER TABLE $tbl DROP COLUMN $col: " . $e->getMessage();
                }
            }
        }

        $pdo = null;
    } else {
        $result['errors'][] = 'Driver non supportato: ' . $dbConfig['connection'];
    }
} catch (Throwable $e) {
    $result['ok'] = false;
    $result['errors'][] = 'Errore: ' . $e->getMessage();
}

echo json_encode($result, JSON_UNESCAPED_SLASHES);
exit(0);
